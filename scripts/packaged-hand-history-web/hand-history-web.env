# SICFUN packaged hand-history web configuration.
# CLI flags and process environment variables override values in this file.

HOST=127.0.0.1
PORT=8080
STATIC_DIR=static
# MODEL_DIR=model
SEED=42
BUNCHING_TRIALS=200
EQUITY_TRIALS=2000
BUDGET_MS=1500
MAX_DECISIONS=12
MAX_UPLOAD_BYTES=2097152
ANALYSIS_TIMEOUT_MS=120000
# Leave MAX_CONCURRENT_JOBS and MAX_QUEUED_JOBS at 0 to use server defaults.
MAX_CONCURRENT_JOBS=0
MAX_QUEUED_JOBS=0
RATE_LIMIT_SUBMITS_PER_MINUTE=6
RATE_LIMIT_STATUS_PER_MINUTE=240
# Optional trusted single-value client-IP header for rate limiting behind a trusted reverse proxy.
# Loopback reverse proxies are trusted automatically; for proxies on other hosts, set RATE_LIMIT_TRUSTED_PROXY_IPS
# to a comma-separated list of exact proxy peer IP literals.
# RATE_LIMIT_CLIENT_IP_HEADER=X-Real-IP
# RATE_LIMIT_TRUSTED_PROXY_IPS=203.0.113.10
SHUTDOWN_GRACE_MS=5000
DRAIN_SIGNAL_FILE=conf/service-drain.signal
# Optional in-process HTTP Basic auth for the UI + protected API routes.
# Prefer config/env over CLI so credentials do not appear in the Java command line.
# BASIC_AUTH_USER=operator
# BASIC_AUTH_PASSWORD=change-me

# Optional platform-user auth. USER_STORE_PATH enables user sessions and profile storage.
# Leave BASIC_AUTH_* unset when using platform-user auth; the modes are mutually exclusive.
# USER_STORE_PATH=conf/users.json
# USER_AUTH_ALLOW_REGISTRATION=true
# USER_AUTH_SESSION_TTL_MS=43200000
# USER_AUTH_COOKIE_SECURE=true

# Optional Google OIDC provider for platform-user auth.
# GOOGLE_OIDC_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_OIDC_CLIENT_SECRET=replace-me
# GOOGLE_OIDC_REDIRECT_URI=https://your-host.example.com/api/auth/oidc/google/callback
